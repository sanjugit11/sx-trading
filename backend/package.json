{
  "name": "sx-trading-backend",
  "version": "1.0.0",
  "description": "SX Trading Suite Backend Service",
  "main": "src/server.ts",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev --name init",
    "db:generate": "prisma generate",
